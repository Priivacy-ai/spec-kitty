{"aggregate_id": "01KT6HVH3QND4Q3KCGH2419N4J", "aggregate_type": "Mission", "event_id": "01KT6HVH75RW3DBCK5SE03G8J7", "event_type": "MissionCreated", "payload": {"created_at": "2026-06-03T10:53:18.840173+00:00", "friendly_name": "Execution-State Domain Remediation \u2014 #1619 Strangler Fig", "mission_id": "01KT6HVH3QND4Q3KCGH2419N4J", "mission_number": null, "mission_slug": "execution-state-domain-remediation-01KT6HVH", "mission_type": "software-dev", "purpose_context": "The spec-kitty runtime has accumulated ~40 command surfaces that independently re-derive execution context (workspace path, feature dir, branch), causing divergent behavior when invoked from different working directories. This mission implements the full Strangler Fig sequence: ratify the domain model via ADRs, build an e2e parity ratchet to gate all changes, introduce the MissionStatus aggregate as the authoritative status owner for the Mission Management domain, enforce the status/ module boundary, add mission identity back-references to run snapshots, and route all residue path-building surfaces through the canonical resolve_action_context entry point.", "purpose_tldr": "Eliminate CWD-dependent execution-context re-derivation across ~40 command surfaces by establishing authoritative domain boundaries and routing all surfaces through a single canonical resolver.", "target_branch": "main", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-06-03T10:53:18.949897+00:00"}
