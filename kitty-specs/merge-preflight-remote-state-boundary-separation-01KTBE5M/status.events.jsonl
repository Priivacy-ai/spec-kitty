{"aggregate_id": "01KTBE5MPD24VTVFHXKCF8MGHN", "aggregate_type": "Mission", "event_id": "01KTBE5MSPH5KV57TGDWT5ZB6B", "event_type": "MissionCreated", "payload": {"created_at": "2026-06-05T08:25:08.047298+00:00", "friendly_name": "Merge Preflight Remote-State Boundary Separation", "mission_id": "01KTBE5MPD24VTVFHXKCF8MGHN", "mission_number": null, "mission_slug": "merge-preflight-remote-state-boundary-separation-01KTBE5M", "mission_type": "software-dev", "purpose_context": "The merge command's preflight check currently tests whether origin/main is in sync before allowing any local branch integration to proceed. This is architecturally inverted: local merges have no dependency on remote state, and the push-safety invariant belongs at the publish layer. This mission corrects the boundary by splitting the safety predicate into local-merge and push-specific concerns, relocating the remote-state fetch to a push adapter, fixing MergeState to capture push intent for correct resume semantics, and updating tests and documentation to match the correct model.", "purpose_tldr": "Separate push-safety invariants from local-merge operations by relocating remote-state checks to the publish layer where they belong.", "target_branch": "main", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-06-05T08:25:08.150648+00:00"}
