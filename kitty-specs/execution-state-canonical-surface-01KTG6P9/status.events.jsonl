{"aggregate_id": "01KTG6P99C3ZGDT2Z97S7ZN5VE", "aggregate_type": "Mission", "event_id": "01KTG6P9MEDJN28HA06MNYBXEP", "event_type": "MissionCreated", "payload": {"created_at": "2026-06-07T04:50:36.972720+00:00", "friendly_name": "Execution-State Canonical Domain Surface", "mission_id": "01KTG6P99C3ZGDT2Z97S7ZN5VE", "mission_number": null, "mission_slug": "execution-state-canonical-surface-01KTG6P9", "mission_type": "software-dev", "purpose_context": "Mission commands today re-derive execution context, paths, and work-package status independently, so the same command can behave differently depending on where it runs. This mission stands up a single owned execution-state domain module with a clean, lean public API over the context objects, then incrementally routes the scattered call sites and status-facade bypasses through it while deleting the duplicated code paths. It is the next implementation slice of the execution-state and context domain-boundary redesign and unblocks reliable, location-independent mission execution.", "purpose_tldr": "Build one canonical execution-state domain surface and strangle duplicated path and status resolution out of the CLI.", "target_branch": "feat/execution-state-strangler", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-06-07T04:50:37.326509+00:00"}
