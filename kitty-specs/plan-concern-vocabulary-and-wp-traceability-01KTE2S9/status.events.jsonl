{"aggregate_id": "01KTE2S951SWFSP0NTQ2NKNQFZ", "aggregate_type": "Mission", "event_id": "01KTE2S98TBGA907FNA9HBV48Q", "event_type": "MissionCreated", "payload": {"created_at": "2026-06-06T09:03:51.970124+00:00", "friendly_name": "Plan Concern Vocabulary and WP Traceability", "mission_id": "01KTE2S951SWFSP0NTQ2NKNQFZ", "mission_number": null, "mission_slug": "plan-concern-vocabulary-and-wp-traceability-01KTE2S9", "mission_type": "software-dev", "purpose_context": "The plan phase currently uses work-package-like language (Parallel Work Analysis, Work Distribution, Agent Assignments) that causes agents and reviewers to treat plan slices as pseudo-WPs. When real WP## units are generated by the tasks phase, they diverge in wording from plan slices with no machine-readable link explaining the translation. This mission introduces a formal implementation concern vocabulary at the plan phase and a plan_concern_refs field in the WP manifest so that every WP can cite which concern(s) it covers, making the plan-to-tasks translation explicit and traceable.", "purpose_tldr": "Introduce implementation concern (IC-##) vocabulary at the plan phase and add concern-to-WP traceability to the task manifest, eliminating plan/task pseudo-WP drift.", "target_branch": "main", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-06-06T09:03:52.090440+00:00"}
