{"aggregate_id": "01KXAST2C4XYGJK3KFYE8FNSCS", "aggregate_type": "Mission", "event_id": "01KXAST2W701K81FS8KVV8TQWW", "event_type": "MissionCreated", "payload": {"created_at": "2026-07-12T09:16:22.788777+00:00", "friendly_name": "Close #2160 Coord-Shadows Read/Gate Arm", "mission_id": "01KXAST2C4XYGJK3KFYE8FNSCS", "mission_number": null, "mission_slug": "coord-shadows-arm-closeout-01KXAST2", "mission_type": "software-dev", "purpose_context": "Five external-contributor fixes for the coord-shadows-primary bug class were aggregated onto this branch but each patched a symptom. This mission aligns them into one coherent slice: a single canonical definition of a work-package subtask row, a fully-closed fail-open in the status gate (so a work package can never reach review with unfinished subtasks on any code path), a recovered execution lane that never re-leaks status files, and a live claim-liveness check that stops false 'stale' warnings. It closes the remaining children of epic #2160 plus two coupled friction issues.", "purpose_tldr": "Make the WP subtask and claim signals trustworthy, coord-correct, and cheap to update \u2014 closing the last read/gate arm of the coord-shadows-primary defect class.", "target_branch": "rework/ray-cluster-aggregation", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-07-12T09:16:23.303668+00:00"}
